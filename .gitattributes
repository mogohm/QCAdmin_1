# Force LF line endings for all text/code files so GitHub renders them multi-line
* text=auto eol=lf

*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.sql  text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.bat  text eol=crlf

# Binary
*.xlsx binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
