# บังคับให้ text/source เป็น LF บน GitHub (กัน CRLF จาก autocrlf บน Windows)
* text=auto eol=lf
*.js text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.html text eol=lf

# batch/powershell ต้องเป็น CRLF (cmd.exe parse) — override * eol=lf ด้านบน
*.bat text eol=crlf
*.ps1 text eol=crlf
